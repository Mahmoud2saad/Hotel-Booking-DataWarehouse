            <component
              refId="Package\Creating The Fact Table\Joins"
              componentClassID="Microsoft.OLEDBSource"
              contactInfo="OLE DB Source;Microsoft Corporation; Microsoft SQL Server; (C) Microsoft Corporation; All Rights Reserved; http://www.microsoft.com/sql/support;7"
              description="OLE DB Source"
              name="Joins"
              usesDispositions="true"
              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset">[dbo].[stg_Booking]</property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    g.stg_guest_id,
    b.hotel,
    b.lead_time,
    b.arrival_date_year,
    b.arrival_date_month,
    b.arrival_date_week_number,
    b.arrival_date_day_of_month,
    b.stays_in_weekend_nights,
    b.stays_in_week_nights,
    b.adults,
    b.children,
    b.babies,
    b.meal,
    b.market_segment,
    b.distribution_channel,
    b.reserved_room_type,
    b.assigned_room_type,
    b.deposit_type,
    b.customer_type,
    r.is_canceled,
    r.adr,
    r.required_car_parking_spaces,
    r.total_of_special_requests,
    r.reservation_status,
    r.reservation_status_date
FROM (
    SELECT *, ROW_NUMBER() OVER (ORDER BY stg_booking_id) AS rn
    FROM HotelDW_Staging.dbo.stg_Booking
) b
INNER JOIN (
    SELECT *, ROW_NUMBER() OVER (ORDER BY stg_reservation_id) AS rn
    FROM HotelDW_Staging.dbo.stg_ReservationStatus
) r ON b.rn = r.rn
INNER JOIN (
    SELECT stg_guest_id, ROW_NUMBER() OVER (ORDER BY stg_guest_id) AS rn
    FROM HotelDW_Staging.dbo.stg_Guest
) g ON b.rn = g.rn</property>
                <property
